{
  "name": "@zapier/zapier-sdk-cli-login",
  "version": "0.9.0",
  "description": "Login and token management for Zapier SDK CLI",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "keywords": [
    "zapier",
    "cli",
    "login",
    "authentication"
  ],
  "author": "",
  "license": "SEE LICENSE IN LICENSE",
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "conf": "^14.0.0",
    "cross-keychain": "^1.1.0",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "rebuild": "pnpm clean && pnpm build",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest"
  }
}