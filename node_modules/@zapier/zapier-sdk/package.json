{
  "name": "@zapier/zapier-sdk",
  "version": "0.41.0",
  "description": "Complete Zapier SDK - combines all Zapier SDK packages",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./define": {
      "source": "./src/define/index.ts",
      "require": {
        "types": "./dist/define.d.ts",
        "default": "./dist/define.cjs"
      },
      "import": {
        "types": "./dist/define.d.mts",
        "default": "./dist/define.mjs"
      }
    },
    "./apps": {
      "source": "./src/define/apps-entrypoint.ts",
      "require": {
        "types": "./dist/apps.d.ts",
        "default": "./dist/apps.cjs"
      },
      "import": {
        "types": "./dist/apps.d.mts",
        "default": "./dist/apps.mjs"
      }
    }
  },
  "browser": {
    "@zapier/zapier-sdk-cli/login": false,
    "@zapier/zapier-sdk-cli-login": false
  },
  "files": [
    "dist",
    "README.md",
    "CLAUDE.md",
    "CHANGELOG.md"
  ],
  "keywords": [
    "zapier",
    "sdk",
    "integrations",
    "actions",
    "workflows",
    "complete"
  ],
  "author": "",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/zapier/zapier-sdk/zapier-sdk.git",
    "directory": "packages/zapier-sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@zapier/zapier-sdk-core": "^0.8.0",
    "zod": "4.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4",
    "@zapier/zapier-sdk-cli-login": "0.9.0"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "rebuild": "pnpm clean && pnpm build",
    "dev": "tsc --watch",
    "typecheck": "tsc --project tsconfig.build.json --noEmit",
    "test": "vitest"
  }
}