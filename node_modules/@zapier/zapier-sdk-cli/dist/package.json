{
    "name": "@zapier/zapier-sdk-cli",
    "version": "0.39.9",
    "description": "Command line interface for Zapier SDK",
    "main": "dist/index.cjs",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "source": "./src/index.ts",
            "require": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.cjs"
            },
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            }
        },
        "./login": {
            "source": "./src/login.ts",
            "require": {
                "types": "./dist/login.d.ts",
                "default": "./dist/login.cjs"
            },
            "import": {
                "types": "./dist/login.d.mts",
                "default": "./dist/login.mjs"
            }
        }
    },
    "bin": {
        "zapier-sdk": "./bin/zapier-sdk.mjs"
    },
    "scripts": {
        "test": "vitest",
        "build": "tsup",
        "clean": "rm -rf dist",
        "rebuild": "pnpm clean && pnpm build",
        "dev": "tsx src/cli.ts",
        "typecheck": "tsc --project tsconfig.build.json --noEmit",
        "prepublishOnly": "node ../../scripts/check-version.js"
    },
    "keywords": [
        "zapier",
        "cli",
        "sdk"
    ],
    "author": "",
    "license": "SEE LICENSE IN LICENSE",
    "files": [
        "dist",
        "bin",
        "templates",
        "README.md",
        "CHANGELOG.md",
        "CLAUDE.md"
    ],
    "repository": {
        "type": "git",
        "url": "https://gitlab.com/zapier/zapier-sdk/zapier-sdk.git",
        "directory": "packages/zapier-sdk-cli"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@zapier/zapier-sdk": "workspace:*",
        "@zapier/zapier-sdk-cli-login": "workspace:*",
        "@zapier/zapier-sdk-mcp": "workspace:*",
        "chalk": "^5.3.0",
        "cli-table3": "^0.6.5",
        "commander": "^12.0.0",
        "esbuild": "^0.25.5",
        "express": "^5.1.0",
        "handlebars": "^4.7.8",
        "inquirer": "^12.6.3",
        "is-installed-globally": "^1.0.0",
        "jsonwebtoken": "^9.0.2",
        "open": "^10.2.0",
        "ora": "^8.2.0",
        "package-json": "^10.0.1",
        "pkce-challenge": "^5.0.0",
        "semver": "^7.7.3",
        "typescript": "^5.8.3",
        "wrap-ansi": "^10.0.0",
        "zod": "4.2.1"
    },
    "devDependencies": {
        "@types/express": "^5.0.3",
        "@types/inquirer": "^9.0.8",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^24.0.1",
        "@types/semver": "^7.7.1",
        "tsup": "^8.5.0",
        "vitest": "^4.1.4"
    }
}
