# Evergreen Landscaping Discord AI Agents - Environment Configuration

# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_GUILD_ID=your_discord_server_id_here  # Optional: For guild-specific commands

# Channel IDs (get these from Discord developer mode)
AGENT_CHANNEL_ID=channel_id_for_agent_discussions
LOG_CHANNEL_ID=channel_id_for_logging

# OpenAI API Keys (one for each agent for distinct personalities)
OPENAI_API_KEY_JORDAN=sk-..._jordans_key
OPENAI_API_KEY_DONNA=sk-..._donnas_key
OPENAI_API_KEY_JERRY=sk-..._jerrys_key

# Optional: OpenAI Organization IDs
# OPENAI_ORG_ID_JORDAN=org-...
# OPENAI_ORG_ID_DONNA=org-...
# OPENAI_ORG_ID_JERRY=org-...

# Model Configuration
OPENAI_MODEL=gpt-4  # or gpt-3.5-turbo, gpt-4-turbo-preview
MAX_TOKENS=600

# Bot Settings
BOT_PREFIX=!
BOT_STATUS=with AI agents | /help

# Logging
LOG_LEVEL=info  # debug, info, warn, error

# Server Settings
PORT=3000
NODE_ENV=production  # development or production

# Database (optional - for conversation persistence)
# DATABASE_URL=postgresql://user:password@localhost:5432/evergreen_agents
# REDIS_URL=redis://localhost:6379

# Security
SESSION_SECRET=your_session_secret_here
CORS_ORIGIN=http://localhost:3000

# ============================================
# How to get these values:
#
# 1. DISCORD_TOKEN:
#    - Go to https://discord.com/developers/applications
#    - Create a new application
#    - Go to "Bot" section
#    - Click "Add Bot"
#    - Copy the token (click "Copy")
#
# 2. DISCORD_CLIENT_ID:
#    - Same Discord Developer Portal
#    - Go to "General Information"
#    - Copy "Application ID"
#
# 3. Channel IDs:
#    - In Discord, enable Developer Mode (Settings > Advanced > Developer Mode)
#    - Right-click on channels, select "Copy ID"
#
# 4. OpenAI API Keys:
#    - Go to https://platform.openai.com/api-keys
#    - Create 3 separate API keys (one for each agent)
#    - Name them: "Jordan Agent", "Donna Agent", "Jerry Agent"
#
# 5. Save this file as `.env` (without .example)
# ============================================